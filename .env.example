# === ADI · variables del gateway LLM (SIEMPRE server-side · NUNCA en el cliente ni en el bundle) ===
# Copiá este archivo a `.env` (gitignoreado) para dev, o seteá estas vars en el dashboard de tu plataforma para prod.
# Con ADI_LLM_ENABLED=false (voiceFlags) el cliente ni llama al gateway → demo determinística, sin key.

# Proveedor: anthropic | openai   (gemini / local son stubs, no implementados)
LLM_PROVIDER=openai

# Modelos: parse = texto→spec (LLM #1) · narrate = output validado→narración (LLM #2)
LLM_MODEL_PARSE=gpt-4o-mini
LLM_MODEL_NARRATE=gpt-4o-mini

# API key del proveedor elegido (SÓLO la que corresponda a LLM_PROVIDER · dejá la otra vacía/comentada)
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Puerto del server de producción (server.js) · opcional · default 8080
# PORT=8080

# === Cliente · build-time (NO secretos · se hornean al bundle vía VITE_) ===
# Activa el camino LLM en el frontend (la UI llama al gateway). default FALSE (demo determinística) si no existe.
# VITE_ADI_LLM_ENABLED=true
# Sub-flag de narración (LLM #2) · default TRUE salvo "false" explícito.
# VITE_ADI_LLM_NARRATE_ENABLED=true
